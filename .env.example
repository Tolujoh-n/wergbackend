## Backend env (example)
## Never commit real secrets. Copy to `.env` locally.

# Database
MONGODB_URI="mongodb+srv://<user>:<pass>@<cluster>/<db>"

# Auth
JWT_SECRET="replace-with-strong-random"

# Optional: extra frontend origins (comma-separated)
# CORS_ORIGINS=https://my-preview.vercel.app
APP_NAME="WeRgame"
PASSWORD_RESET_SECRET="replace-with-strong-random"
PASSWORD_RESET_CODE_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
# PASSWORD_RESET_RESEND_SECONDS=60

# SendGrid (password reset + free-play email verification)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="no-reply@yourdomain.com"
SENDGRID_FROM_NAME="WeRgame"

# Free-play email OTP (before first free prediction; re-verify every 30 days)
EMAIL_VERIFY_RESEND_SECONDS=60
EMAIL_VERIFY_CODE_TTL_MINUTES=10
EMAIL_VERIFY_MAX_ATTEMPTS=5
EMAIL_VERIFY_VALID_DAYS=30
# EMAIL_VERIFY_SECRET="optional-separate-secret"
# When SendGrid is NOT configured, log OTP codes to the backend console:
# EMAIL_VERIFY_DEV_LOG=true
# PASSWORD_RESET_DEV_LOG=true
# When SendGrid IS configured, emails are sent via SendGrid (dev flags do not block email).

# Cloudflare Turnstile (login + signup)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Frontend can also use REACT_APP_TURNSTILE_SITE_KEY (same value as TURNSTILE_SITE_KEY)

# Legacy SMS (removed — no longer used)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""

# Blockchain — Base mainnet (chainId 8453)
CLAIM_AUTH_PRIVATE_KEY="<private key>"
CONTRACT_ADDRESS="0x..."
CHAIN_ID=8453
# Read-only RPC (balance checks, contract views, USDC reads)
BASE_READ_RPC_URL=https://mainnet.base.org
# Write RPC (relayer gas-drip, settlement bot — signed transactions)
BASE_WRITE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# Fallback for both read and write when primary is rate-limited
BASE_RPC_URL_FALLBACK=https://base-rpc.publicnode.com
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_DECIMALS=6
BLOCK_EXPLORER=https://basescan.org

# Optional: absolute path to WeRgame JSON with an `abi` array (defaults to ./abi/WeRgame.json inside backend deploy bundle)
# WERGAME_CONTRACT_ARTIFACT_PATH=

# Orderbook settlement outbox: jobs move to status `dead` after this many failed attempts (relayer/RPC errors)
SETTLEMENT_OUTBOX_MAX_ATTEMPTS=25

# Gas relayer — drips Base ETH to linked wallets so users can boost/trade without holding ETH
# Fund this wallet with Base ETH. Use RELAYER_PRIVATE_KEY or RELAYER_MNEMONIC (+ optional RELAYER_DERIVATION_PATH).
RELAYER_PRIVATE_KEY=
# RELAYER_MNEMONIC=
# RELAYER_DERIVATION_PATH=m/44'/60'/0'/0/0
GASDRIP_MIN_BALANCE_ETH=0.00005
GASDRIP_SEND_AMOUNT_ETH=0.0001

# Off-chain market maker: MongoDB User document _id (24-char hex). User must have a linked wallet
# (POST /api/auth/wallets/link) and USDC in the contract trading vault for that address.
# Resolve: from backend folder, `node scripts/printMmUserId.js admin@wergame.com`
MARKET_MAKER_USER_ID=698508321490f2cbfadd6241
GOOGLE_CLIENT_ID=646054314617-ugk41v8q9o159s7u478v0afh0u9rmeqd.apps.googleusercontent.com

# cloudinary
CLOUDINARY_CLOUD_NAME=dxufkhffc
CLOUDINARY_API_KEY=226735658796427
CLOUDINARY_API_SECRET=YjGUXxKXTl4AJVKIauAyVAOBh7w

# refferal system
FRONTEND_URL=http://localhost:3000